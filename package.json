{
  "name": "nolimitseradeals",
  "version": "0.0.926",
  "private": true,
  "scripts": {
    "android": "react-native run-android --mode=StagingDebug --appId=com.nolimitseradeals.staging",
    "android:staging": "react-native run-android --mode=StagingDebug --appId=com.nolimitseradeals.staging",
    "android:prod": "react-native run-android --mode=ProductionDebug --appId=com.nolimitseradeals",
    "lint": "eslint .",
    "start": "react-native start",
    "test": "jest",
    "ios": "react-native run-ios --simulator='iPhone 17 Pro'",
    "ios:max": "react-native run-ios --simulator='iPhone 17 Pro Max'",
    "ios:se": "react-native run-ios --simulator='iPhone SE (3rd generation)'",
    "ios:ipad": "react-native run-ios --simulator='iPad Pro (12.9-inch)'",
    "clean": "cd android && ./gradlew clean && cd ../ios && xcodebuild clean && cd ..",
    "reset-cache": "npx react-native start --reset-cache",
    "pod-install": "cd ios && pod install && cd ..",
    "postinstall": "npx @sentry/cli --version || echo 'Warning: Sentry CLI not found'"
  },
  "dependencies": {
    "@react-native-async-storage/async-storage": "^2.1.0",
    "@react-native-community/datetimepicker": "^8.5.0",
    "@react-native-community/masked-view": "^0.1.11",
    "@react-native-vector-icons/fontawesome": "^12.4.0",
    "@react-native-vector-icons/fontawesome5": "^12.3.0",
    "@react-native-vector-icons/ionicons": "^12.3.0",
    "@react-native-vector-icons/material-icons": "^12.4.0",
    "@react-native/new-app-screen": "0.81.1",
    "@react-navigation/bottom-tabs": "^7.2.0",
    "@react-navigation/native": "^7.1.17",
    "@react-navigation/native-stack": "^7.3.26",
    "@react-navigation/stack": "^7.4.9",
    "@sentry/react-native": "^7.6.0",
    "react": "19.1.0",
    "react-native": "0.81.1",
    "react-native-app-auth": "^8.1.0",
    "react-native-barcode-builder": "^2.0.0",
    "react-native-barcode-creator": "^0.1.8",
    "react-native-bootsplash": "^6.3.11",
    "react-native-config": "^1.5.9",
    "react-native-contacts": "^8.0.7",
    "react-native-gesture-handler": "^2.28.0",
    "react-native-iap": "^14.5.0",
    "react-native-image-picker": "^8.2.1",
    "react-native-keychain": "^9.1.0",
    "react-native-linear-gradient": "^2.8.3",
    "react-native-maps": "^1.26.18",
    "react-native-nitro-modules": "^0.31.5",
    "react-native-permissions": "^5.4.2",
    "react-native-reanimated": "^4.1.3",
    "react-native-safe-area-context": "^5.6.1",
    "react-native-screens": "^4.16.0",
    "react-native-sensors": "^7.3.6",
    "react-native-sms": "^1.12.0",
    "react-native-svg": "^15.14.0",
    "react-native-typography": "^1.4.1",
    "react-native-worklets": "^0.6.1"
  },
  "devDependencies": {
    "@babel/core": "^7.25.2",
    "@babel/preset-env": "^7.25.3",
    "@babel/runtime": "^7.25.0",
    "@react-native-community/cli": "20.0.0",
    "@react-native-community/cli-platform-android": "20.0.0",
    "@react-native-community/cli-platform-ios": "20.0.0",
    "@react-native/babel-preset": "0.81.1",
    "@react-native/eslint-config": "0.81.1",
    "@react-native/metro-config": "0.81.1",
    "@react-native/typescript-config": "0.81.1",
    "@sentry/cli": "^2.58.2",
    "@types/jest": "^29.5.13",
    "@types/react": "^19.1.0",
    "@types/react-native-vector-icons": "^6.4.18",
    "@types/react-test-renderer": "^19.1.0",
    "eslint": "^8.19.0",
    "jest": "^29.6.3",
    "prettier": "2.8.8",
    "react-native-svg-transformer": "^1.5.2",
    "react-test-renderer": "19.1.0",
    "typescript": "^5.8.3"
  },
  "engines": {
    "node": ">=20"
  }
}

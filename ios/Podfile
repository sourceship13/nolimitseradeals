def node_require(script)
  # Resolve script with node to allow for hoisting
  require Pod::Executable.execute_command('node', ['-p',
    "require.resolve(
      '#{script}',
      {paths: [process.argv[1]]},
    )", __dir__]).strip
end

node_require('react-native/scripts/react_native_pods.rb')
node_require('react-native-permissions/scripts/setup.rb')

# Configure react-native-permissions
setup_permissions([
  'Contacts',
  'LocationWhenInUse'
])

platform :ios, min_ios_version_supported
prepare_react_native_project!

# Keep New Architecture enabled (required by Reanimated)
ENV['RCT_NEW_ARCH_ENABLED'] = '1'

# React Native Maps dependencies
rn_maps_path = '../node_modules/react-native-maps'
pod 'react-native-maps/Google', :path => rn_maps_path

linkage = ENV['USE_FRAMEWORKS']
if linkage != nil
  Pod::UI.puts "Configuring Pod with #{linkage}ally linked Frameworks".green
  use_frameworks! :linkage => linkage.to_sym
end

def shared_pods
  config = use_native_modules!
  
  use_react_native!(
    :path => config[:reactNativePath],
    :hermes_enabled => true,
    :fabric_enabled => true,
    :app_path => "#{Pod::Config.instance.installation_root}/.."
  )
end

target 'nolimitseradeals-staging' do
  shared_pods
end

target 'nolimitseradeals-prod' do
  shared_pods
end
post_install do |installer|
  react_native_post_install(
    installer,
    "../node_modules/react-native",
    :mac_catalyst_enabled => false
  )
  
  # Aggressive Xcode 16 duplicate bundle fix
  installer.pods_project.build_configurations.each do |config|
    config.build_settings['CLANG_ALLOW_NON_MODULAR_INCLUDES_IN_FRAMEWORK_MODULES'] = 'YES'
  end
  
  installer.pods_project.targets.each do |target|
    target.build_configurations.each do |config|
      config.build_settings['DEAD_CODE_STRIPPING'] = 'YES'
      
      if target.respond_to?(:product_type) && target.product_type == "com.apple.product-type.bundle"
        config.build_settings['CODE_SIGNING_ALLOWED'] = 'NO'
        config.build_settings['CODE_SIGNING_REQUIRED'] = 'NO'
        config.build_settings['CODE_SIGN_IDENTITY'] = ''
      end
      
      if target.name.include?('React-Core') && target.name.include?('privacy')
        config.build_settings['ENABLE_USER_SCRIPT_SANDBOXING'] = 'NO'
      end
    end
  end
  
  # Nuclear option: Completely remove one of the duplicate privacy bundle targets
  targets_to_remove = []
  installer.pods_project.targets.each do |target|
    if target.name.include?('React-Core') && target.name.include?('privacy') && target.name != 'React-Core.common-React-Core_privacy'
      targets_to_remove << target
    end
  end
  
  targets_to_remove.each do |target|
    puts "Removing duplicate privacy bundle target: #{target.name}"
    target.build_phases.each { |phase| phase.clear }
    installer.pods_project.targets.delete(target)
  end
  
  # Remove references from aggregate targets
  installer.aggregate_targets.each do |aggregate_target|
    aggregate_target.pod_targets.delete_if do |pod_target|
      targets_to_remove.any? { |t| pod_target.name == t.name }
    end
  end
  
  installer.pods_project.save
  
  # Post-save: Clean up generated files
  `find Pods/Target\\ Support\\ Files -name "*.xcconfig" -type f -exec sed -i '' '/React-Core-f955c501\\/React-Core_privacy\\.bundle/d' {} \\;`
  `find Pods/Target\\ Support\\ Files -name "*-resources.sh" -type f -exec sed -i '' '/React-Core-f955c501\\/React-Core_privacy\\.bundle/d' {} \\;`
end
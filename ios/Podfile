def node_require(script)
  # Resolve script with node to allow for hoisting
  require Pod::Executable.execute_command('node', ['-p',
    "require.resolve(
      '#{script}',
      {paths: [process.argv[1]]},
    )", __dir__]).strip
end

node_require('react-native/scripts/react_native_pods.rb')
node_require('react-native-permissions/scripts/setup.rb')

# Configure react-native-permissions
setup_permissions([
  'Contacts',
  'LocationWhenInUse'
])

platform :ios, min_ios_version_supported
prepare_react_native_project!

# Set environment variable for react-native-maps to use Google Maps
ENV['RCT_NEW_ARCH_ENABLED'] = '1'

# React Native Maps dependencies
rn_maps_path = '../node_modules/react-native-maps'
pod 'react-native-maps/Google', :path => rn_maps_path

linkage = ENV['USE_FRAMEWORKS']
if linkage != nil
  Pod::UI.puts "Configuring Pod with #{linkage}ally linked Frameworks".green
  use_frameworks! :linkage => linkage.to_sym
end

def shared_pods
  config = use_native_modules!
  
  # react-native-permissions v5.x uses auto-linking
  use_react_native!(
    :path => config[:reactNativePath],
    # An absolute path to your application root.
    :app_path => "#{Pod::Config.instance.installation_root}/.."
  )
  
  return config
end

target 'nolimitseradeals-staging' do
  config = shared_pods
end

target 'nolimitseradeals-prod' do
  config = shared_pods
end

post_install do |installer|
  # https://github.com/facebook/react-native/blob/main/packages/react-native/scripts/react_native_pods.rb#L197-L202
  react_native_post_install(
    installer,
    "../node_modules/react-native",
    :mac_catalyst_enabled => false,
  )
  
  # Fix Xcode 16 duplicate React-Core_privacy bundle issue
  installer.pods_project.targets.each do |target|
    target.build_configurations.each do |config|
      # Disable code signing for all resource bundles
      if target.respond_to?(:product_type) && target.product_type == "com.apple.product-type.bundle"
        config.build_settings['CODE_SIGNING_ALLOWED'] = 'NO'
        config.build_settings['CODE_SIGNING_REQUIRED'] = 'NO'
        config.build_settings['CODE_SIGN_IDENTITY'] = ''
      end
      
      # Fix for privacy bundle targets
      if target.name.include?('React-Core') && target.name.include?('privacy')
        config.build_settings['ENABLE_USER_SCRIPT_SANDBOXING'] = 'NO'
      end
    end
  end
  
  # Fix the copy resources script to remove duplicate privacy bundles
  installer.aggregate_targets.each do |aggregate_target|
    aggregate_target.xcconfigs.each do |config_name, config_file|
      xcconfig_path = aggregate_target.xcconfig_path(config_name)
      if File.exist?(xcconfig_path)
        xcconfig = File.read(xcconfig_path)
        
        # Find all privacy bundle references
        privacy_bundle_pattern = /\$\{PODS_CONFIGURATION_BUILD_DIR\}\/React-Core[^\/\s]*\/React-Core_privacy\.bundle/
        privacy_bundles = xcconfig.scan(privacy_bundle_pattern).uniq
        
        if privacy_bundles.length > 1
          puts "Found #{privacy_bundles.length} privacy bundles, keeping only the first one"
          # Keep only the first occurrence
          first_bundle = privacy_bundles.first
          privacy_bundles[1..-1].each do |duplicate_bundle|
            xcconfig.gsub!(/ #{Regexp.escape(duplicate_bundle)}/, '')
          end
          File.write(xcconfig_path, xcconfig)
        end
      end
    end
    
    # Also fix the copy resources script
    copy_resources_script = File.join(aggregate_target.support_files_dir, 'Pods-' + aggregate_target.name + '-resources.sh')
    if File.exist?(copy_resources_script)
      script_content = File.read(copy_resources_script)
      
      # Find all install_resource calls for privacy bundles
      privacy_installs = script_content.scan(/install_resource.*React-Core.*privacy\.bundle.*$/)
      
      if privacy_installs.length > 1
        puts "Found #{privacy_installs.length} privacy bundle install calls, keeping only the first one"
        # Remove duplicate install_resource calls
        privacy_installs[1..-1].each do |duplicate_line|
          script_content.gsub!(/#{Regexp.escape(duplicate_line)}\n/, '')
        end
        File.write(copy_resources_script, script_content)
      end
    end
  end
  
  installer.pods_project.save
end
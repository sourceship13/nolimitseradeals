default_platform(:ios)

platform :ios do
  desc "Build and upload STAGING to TestFlight"
  lane :staging do
    # Use keychain created by CircleCI
    keychain_name = "fastlane.keychain-db"
    keychain_password = "temp_password"
    
    # Setup certificates with Match for STAGING
    match(
      type: "appstore",
      readonly: true,
      app_identifier: "org.sera.dev.nolimitsera.staging",
      keychain_name: keychain_name,
      keychain_password: keychain_password,
      git_url: "git@github.com-fastlane-match:ajp-sourceship/nolimitseradeals_fastlane_match.git"
    )
    
    profile_name = ENV["sigh_org.sera.dev.nolimitsera.staging_appstore_profile-name"]
    
    # Set partition list for codesign access
    sh("security set-key-partition-list -S apple-tool:,apple:,codesign: -s -k #{keychain_password} ~/Library/Keychains/#{keychain_name} || true")
    sleep(2)
    sh("security set-key-partition-list -S apple-tool:,apple: -s -k #{keychain_password} ~/Library/Keychains/#{keychain_name}")
    sh("security unlock-keychain -p #{keychain_password} ~/Library/Keychains/#{keychain_name}")
    
    # Increment build number for staging target
    increment_build_number(
      xcodeproj: "nolimitseradeals.xcodeproj",
      build_number: ENV["CIRCLE_BUILD_NUM"] || Time.now.to_i.to_s
    )
    
    # Remove problematic Hermes file
    sh("rm -rf ../Pods/hermes-engine/destroot/Library/Frameworks/universal/hermes.framework/hermes || true")
    
    # Update code signing settings for STAGING
    update_code_signing_settings(
      use_automatic_signing: false,
      path: "nolimitseradeals.xcodeproj",
      targets: ["nolimitseradeals-staging"],
      team_id: "CM52HNMXXW",
      code_sign_identity: "Apple Distribution",
      bundle_identifier: "org.sera.dev.nolimitsera.staging",
      profile_name: profile_name,
      build_configurations: ["Release"]
    )
    
    # Set ENVFILE for React Native bundler
    ENV['ENVFILE'] = '.env.staging'
    
    # Build the STAGING app
    build_app(
      workspace: "nolimitseradeals.xcworkspace",
      scheme: "nolimitseradeals-staging",
      clean: true,
      export_method: "app-store",
      configuration: "Release",
      output_directory: "./build",
      output_name: "nolimitseradeals-staging.ipa",
      codesigning_identity: "Apple Distribution",
      xcargs: "ENVFILE=.env.staging",
      export_options: {
        method: "app-store",
        uploadBitcode: false,
        uploadSymbols: true,
        compileBitcode: false,
        provisioningProfiles: {
          "org.sera.dev.nolimitsera.staging" => profile_name
        },
        signingStyle: "manual",
        stripSwiftSymbols: true,
        manageAppVersionAndBuildNumber: false
      }
    )
    
    # Create API key
    api_key = app_store_connect_api_key(
      key_id: ENV["APP_STORE_CONNECT_API_KEY_KEY_ID"],
      issuer_id: ENV["APP_STORE_CONNECT_API_KEY_ISSUER_ID"],
      key_content: Base64.decode64(ENV["APP_STORE_CONNECT_API_KEY_CONTENT"])
    )
    
    # Upload to TestFlight (staging app)
    upload_to_testflight(
      api_key: api_key,
      skip_waiting_for_build_processing: true,
      skip_submission: true,
      ipa: "./build/nolimitseradeals-staging.ipa"
    )
    
    UI.success("✅ Staging build uploaded to TestFlight!")
  end

  desc "Build and upload PRODUCTION to TestFlight"
  lane :production do
    # Use keychain created by CircleCI
    keychain_name = "fastlane.keychain-db"
    keychain_password = "temp_password"
    
    # Setup certificates with Match for PRODUCTION
    match(
      type: "appstore",
      readonly: true,
      app_identifier: "org.sera.dev.nolimitsera",
      keychain_name: keychain_name,
      keychain_password: keychain_password,
      git_url: "git@github.com-fastlane-match:ajp-sourceship/nolimitseradeals_fastlane_match.git"
    )
    
    profile_name = ENV["sigh_org.sera.dev.nolimitsera_appstore_profile-name"]
    
    # Set partition list for codesign access
    sh("security set-key-partition-list -S apple-tool:,apple:,codesign: -s -k #{keychain_password} ~/Library/Keychains/#{keychain_name} || true")
    sleep(2)
    sh("security set-key-partition-list -S apple-tool:,apple: -s -k #{keychain_password} ~/Library/Keychains/#{keychain_name}")
    sh("security unlock-keychain -p #{keychain_password} ~/Library/Keychains/#{keychain_name}")
    
    # Increment build number for production target
    increment_build_number(
      xcodeproj: "nolimitseradeals.xcodeproj",
      build_number: ENV["CIRCLE_BUILD_NUM"] || Time.now.to_i.to_s
    )
    
    # Remove problematic Hermes file
    sh("rm -rf ../Pods/hermes-engine/destroot/Library/Frameworks/universal/hermes.framework/hermes || true")
    
    # Update code signing settings for PRODUCTION
    update_code_signing_settings(
      use_automatic_signing: false,
      path: "nolimitseradeals.xcodeproj",
      targets: ["nolimitseradeals-prod"],
      team_id: "CM52HNMXXW",
      code_sign_identity: "Apple Distribution",
      bundle_identifier: "org.sera.dev.nolimitsera",
      profile_name: profile_name,
      build_configurations: ["Release"]
    )
    
    # Set ENVFILE for React Native bundler
    ENV['ENVFILE'] = '.env.production'
    
    # Build the PRODUCTION app
    build_app(
      workspace: "nolimitseradeals.xcworkspace",
      scheme: "nolimitseradeals-prod",
      clean: true,
      export_method: "app-store",
      configuration: "Release",
      output_directory: "./build",
      output_name: "nolimitseradeals.ipa",
      codesigning_identity: "Apple Distribution",
      xcargs: "ENVFILE=.env.production",
      export_options: {
        method: "app-store",
        uploadBitcode: false,
        uploadSymbols: true,
        compileBitcode: false,
        provisioningProfiles: {
          "org.sera.dev.nolimitsera" => profile_name
        },
        signingStyle: "manual",
        stripSwiftSymbols: true,
        manageAppVersionAndBuildNumber: false
      }
    )
    
    # Create API key
    api_key = app_store_connect_api_key(
      key_id: ENV["APP_STORE_CONNECT_API_KEY_KEY_ID"],
      issuer_id: ENV["APP_STORE_CONNECT_API_KEY_ISSUER_ID"],
      key_content: Base64.decode64(ENV["APP_STORE_CONNECT_API_KEY_CONTENT"])
    )
    
    # Upload to TestFlight (production app)
    upload_to_testflight(
      api_key: api_key,
      skip_waiting_for_build_processing: true,
      skip_submission: true,
      ipa: "./build/nolimitseradeals.ipa"
    )
    
    UI.success("✅ Production build uploaded to TestFlight!")
  end
  
  # Keep 'beta' as an alias for staging for backwards compatibility
  lane :beta do
    staging
  end
end
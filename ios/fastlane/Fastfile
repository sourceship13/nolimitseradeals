default_platform(:ios)

platform :ios do
  desc "Push a new beta build to TestFlight"
  lane :beta do
    # Sync code signing using Match
    match(
      type: "appstore",
      app_identifier: "org.sera.dev.nolimitsera",
      readonly: true,
      keychain_name: "temp.keychain",
      keychain_password: ""
    )
    
    # Get the profile UUID
    profile_uuid = ENV["sigh_org.sera.dev.nolimitsera_appstore"]
    
    # Increment build number
    increment_build_number(
      build_number: ENV["CIRCLE_BUILD_NUM"] || latest_testflight_build_number + 1
    )
    
    # Disable automatic code signing in the project
    disable_automatic_code_signing(
      path: "nolimitseradeals.xcodeproj",
      team_id: ENV["APPLE_TEAM_ID"]
    )
    
    # Update project settings to use manual signing with the profile
    update_project_provisioning(
      xcodeproj: "nolimitseradeals.xcodeproj",
      profile: profile_uuid,
      target_filter: "nolimitseradeals",
      build_configuration: "Release"
    )
    
    # Build the app
    build_app(
      workspace: "nolimitseradeals.xcworkspace",
      scheme: "nolimitseradeals",
      configuration: "Release",
      export_method: "app-store",
      output_directory: "./build",
      output_name: "nolimitseradeals.ipa",
      clean: true,
      codesigning_identity: "Apple Distribution",
      xcargs: "DEVELOPMENT_TEAM=#{ENV['APPLE_TEAM_ID']} PROVISIONING_PROFILE_SPECIFIER=#{profile_uuid}",
      buildlog_path: "./buildlogs",
      suppress_xcode_output: false,
      export_options: {
        method: "app-store",
        teamID: ENV["APPLE_TEAM_ID"],
        provisioningProfiles: { 
          "org.sera.dev.nolimitsera" => "match AppStore org.sera.dev.nolimitsera"
        }
      }
    )
    
    # Upload to TestFlight
    upload_to_testflight(
      skip_waiting_for_build_processing: true,
      skip_submission: true,
      distribute_external: false,
      notify_external_testers: false
    )
  end
  
  desc "Push a new staging build to TestFlight"
  lane :staging do
    # Same as beta
    beta
  end
end
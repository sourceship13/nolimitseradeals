default_platform(:ios)

platform :ios do
  desc "Build and upload to TestFlight"
  lane :beta do
    # Setup the keychain for Match
    keychain_name = "fastlane.keychain-db"
    keychain_password = "temp_password"
    
    # Setup certificates with Match
    match(
      type: "appstore",
      app_identifier: "org.sera.dev.nolimitsera",
      readonly: true,
      git_url: "git@github.com-fastlane-match:ajp-sourceship/nolimitseradeals_fastlane_match.git",
      keychain_name: keychain_name,
      keychain_password: keychain_password
    )
    
    # Manually set partition list for codesign access - try multiple times
    sh("security set-key-partition-list -S apple-tool:,apple:,codesign: -s -k #{keychain_password} ~/Library/Keychains/#{keychain_name} || true")
    
    # Wait a moment for keychain to settle
    sleep(2)
    
    # Try setting it again
    sh("security set-key-partition-list -S apple-tool:,apple: -s -k #{keychain_password} ~/Library/Keychains/#{keychain_name}")
    
    # Verify certificate is accessible
    identities = sh("security find-identity -v -p codesigning ~/Library/Keychains/#{keychain_name}")
    puts "Available identities:\n#{identities}"
    
    # Make absolutely sure the keychain is unlocked
    sh("security unlock-keychain -p #{keychain_password} ~/Library/Keychains/#{keychain_name}")
    
    # Increment build number only
    increment_build_number(
      build_number: ENV["CIRCLE_BUILD_NUM"] || Time.now.to_i.to_s
    )
    
    # Get the provisioning profile name that Match downloaded
    profile_name = ENV["sigh_org.sera.dev.nolimitsera_appstore_profile-name"]
    
    # Upload to TestFlight
    puts "🔍 Debugging credentials:"
    puts "FASTLANE_USER: #{ENV['FASTLANE_USER']}"
    puts "Password set: #{!ENV['FASTLANE_APPLE_APPLICATION_SPECIFIC_PASSWORD'].nil? && !ENV['FASTLANE_APPLE_APPLICATION_SPECIFIC_PASSWORD'].empty?}"
    puts "Password length: #{ENV['FASTLANE_APPLE_APPLICATION_SPECIFIC_PASSWORD']&.length}"

    upload_to_testflight(
      skip_waiting_for_build_processing: true,
      skip_submission: true,
      username: ENV['FASTLANE_USER'],
      apple_id: ENV['APPLE_APP_ID']  # Add your app's numeric Apple ID
    )

    # Build the app with explicit profile mapping
    build_app(
      workspace: "nolimitseradeals.xcworkspace",
      scheme: "nolimitseradeals",
      clean: true,
      export_method: "app-store",
      output_directory: "./output/gym",
      output_name: "nolimitseradeals.ipa",
      skip_profile_detection: true,
      codesigning_identity: "Apple Distribution",
      xcargs: "-allowProvisioningUpdates",  # Add this to help with signing
      export_options: {
        method: "app-store",
        provisioningProfiles: {
          "org.sera.dev.nolimitsera" => profile_name
        },
        stripSwiftSymbols: true
      }
    )
    
    # Upload to TestFlight
    upload_to_testflight(
      skip_waiting_for_build_processing: true,
      skip_submission: true
    )
    
    puts "✅ Build uploaded to TestFlight!"
  end
end
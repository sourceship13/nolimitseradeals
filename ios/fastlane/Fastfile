default_platform(:ios)

platform :ios do
  desc "Build and upload to TestFlight"
  lane :beta do
    # Setup the keychain for Match
    keychain_name = "fastlane.keychain-db"
    keychain_password = "temp_password"
    
    # Setup certificates with Match
    match(
      type: "appstore",
      app_identifier: "org.sera.dev.nolimitsera",
      readonly: true,
      git_url: "git@github.com-fastlane-match:ajp-sourceship/nolimitseradeals_fastlane_match.git",
      keychain_name: keychain_name,
      keychain_password: keychain_password,
      verbose: true
    )
    
    # Manually set partition list for codesign access
    sh("security set-key-partition-list -S apple-tool:,apple:,codesign: -s -k #{keychain_password} ~/Library/Keychains/#{keychain_name}")
    
    # Verify certificate is accessible
    sh("security find-identity -v -p codesigning ~/Library/Keychains/#{keychain_name}")
    
    # Increment build number
    increment_build_number(
      build_number: ENV["CIRCLE_BUILD_NUM"] || Time.now.to_i.to_s
    )
    
    # Get the provisioning profile from Match
    profile_env_name = "sigh_org.sera.dev.nolimitsera_appstore_profile-name"
    
    update_build_setting(
      xcodeproj: "nolimitseradeals.xcodeproj",
      key: "SWIFT_VERSION",
      value: "5.0"
    )

    # Build the app with explicit profile mapping
    build_app(
      workspace: "nolimitseradeals.xcworkspace",
      scheme: "nolimitseradeals",
      clean: true,
      export_method: "app-store",
      output_directory: "./output/gym",
      output_name: "nolimitseradeals.ipa",
      skip_profile_detection: true,
      export_options: {
        method: "app-store",
        provisioningProfiles: {
          "org.sera.dev.nolimitsera" => profile_name
        },
        stripSwiftSymbols: true  # Add this
      }
    )
    
    # Upload to TestFlight
    upload_to_testflight(
      skip_waiting_for_build_processing: true,
      skip_submission: true
    )
    
    puts "✅ Build uploaded to TestFlight!"
  end
end
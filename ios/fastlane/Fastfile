default_platform(:ios)

platform :ios do
  desc "Build app"
  lane :beta do
    # Increment build number
    increment_build_number(
      build_number: ENV["CIRCLE_BUILD_NUM"] || Time.now.to_i.to_s
    )
    
    # Build the app with explicit provisioning profile name
    build_app(
      workspace: "nolimitseradeals.xcworkspace",
      scheme: "nolimitseradeals",
      export_method: "app-store",
      output_directory: "./output/gym",
      output_name: "nolimitseradeals.ipa",
      codesigning_identity: "Apple Distribution",
      export_options: {
        method: "app-store",
        signingStyle: "manual",
        provisioningProfiles: {
          "org.sera.dev.nolimitsera" => ENV["PROVISIONING_PROFILE_NAME"]
        }
      }
    )
    
    puts "✅ Build complete!"
  end
end